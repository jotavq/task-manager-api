<h1>Postagens</h1>
<p class="subtitle">Cadastre uma nova postagem <a href="/cadastro">clicando aqui</a></p>

{{#if posts.length}}
    {{#each posts}}
        <article class="post-item">
            <time class="post-date">{{formatarData createdAt}}</time>
            <h2 class="post-title">{{titulo}}</h2>
            <p class="post-content">{{conteudo}}</p>
            <div class="post-actions">
                <a href="/editar/{{id}}" class="btn btn-edit">Editar</a>
                <form action="/deletar/{{id}}" method="POST" style="display:inline;margin:0" onsubmit="return confirm('Tem certeza que deseja excluir essa postagem? Esta ação não pode ser desfeita.')">
                    <button type="submit" class="btn btn-delete">Excluir</button>
                </form>
            </div>
        </article>
    {{/each}}
{{else}}
    <p class="empty-state">Nenhuma postagem cadastrada ainda.</p>
{{/if}}
