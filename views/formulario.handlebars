<div class="form-header">
    <h1>{{#if editando}}Editar postagem{{else}}Nova postagem{{/if}}</h1>
    <p>{{#if editando}}Altere os campos abaixo e salve as mudanças.{{else}}Preencha os campos para cadastrar.{{/if}}</p>
</div>

{{#if editando}}
<form action="/editar/{{post.id}}" method="POST" class="form-card">
{{else}}
<form action="/add" method="POST" class="form-card">
{{/if}}
    <div class="form-group">
        <label for="titulo">Título</label>
        <input type="text" id="titulo" name="titulo" value="{{post.titulo}}" placeholder="Digite o título" required>
    </div>
    <div class="form-group">
        <label for="conteudo">Conteúdo</label>
        <textarea id="conteudo" name="conteudo" placeholder="Digite o conteúdo" required>{{post.conteudo}}</textarea>
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-primary">{{#if editando}}Salvar alterações{{else}}Cadastrar{{/if}}</button>
        <a href="/" class="btn btn-secondary">Voltar</a>
    </div>
</form>
